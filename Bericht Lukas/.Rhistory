#i) - Gleichverteilungstest
#Wir erschaffen zuerst eine Häufigkeitstabelle
random.table <- table(random)
#Jetzt führen wir unseren Test durch
test.result <- chisq.test(random.table)
#Wir geben unser Ergebnis aus:
print(test.random)
#i) - Gleichverteilungstest
#Wir erschaffen zuerst eine Häufigkeitstabelle
random.table <- table(random)
#Jetzt führen wir unseren Test durch
test.result <- chisq.test(random.table)
#Wir geben unser Ergebnis aus:
print(test.result)
#ii) - Gaptest
#i) - Gleichverteilungstest
#Wir erschaffen zuerst eine Häufigkeitstabelle
random.table <- table(random)
#Jetzt führen wir unseren Test durch
test.result <- chisq.test(random.table)
#Wir geben unser Ergebnis aus:
print(test.result)
#ii) - Gaptest
#Wir nehmen  alle Zahlen aus dem Vektor bis auf die letze
r.t <- random[1 : (length(random) - 1)]
#Wir nehmen alle Zahlen ab der zweiten
r.t.plus.1 <- random[2:length(random)]
#Jetzt haben wir alle Werte der Tabelle um eins versetzt so das
#wir die Wertepaare leicht vergleichen können
#Wir erstellen eine Kreuztabelle
pairs.table <- table(r.t, r.t.plus.1)
#Jetzt führen wir wieder den test durch
chisq.test(pairs.table)
#i) - Gleichverteilungstest
#Wir erschaffen zuerst eine Häufigkeitstabelle
random.table <- table(random)
#Jetzt führen wir unseren Test durch
test.result <- chisq.test(random.table)
#Wir geben unser Ergebnis aus:
print(test.result)
#ii) - Gaptest
#Wir nehmen  alle Zahlen aus dem Vektor bis auf die letze
r.t <- random[1 : (length(random) - 1)]
#Wir nehmen alle Zahlen ab der zweiten
r.t.plus.1 <- random[2:length(random)]
#Jetzt haben wir alle Werte der Tabelle um eins versetzt so das
#wir die Wertepaare leicht vergleichen können
#Wir erstellen eine Kreuztabelle
pairs.table <- table(r.t, r.t.plus.1)
#Jetzt führen wir wieder den test durch
chisq.test(pairs.table)
