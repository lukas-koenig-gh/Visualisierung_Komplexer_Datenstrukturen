#Hypergeometrische Verteilung zu finden
ggplot(test.data.rnorm, aes(x = x)) +
#Wir erstellen unser Histogramm mit den Simulierten Daten
geom_histogram(aes(y = after_stat(density)), bins = 50, fill = "lightblue", color = "black") +
#Wir zeichnen wieder eine linie der richtigen normalverteilung drüber um zu gucken wie nah wir dran sind
#Da wir diesesmal kontinuierliche Werte haben können wir stat_function verwenden
stat_function(fun = dnorm,
args = list(mean = 0, sd = 1),
color = "red",
size = 1) +
#Achsenbeschriftung
labs(title = "Normalverteilung",
x = "Anzahl Treffer",
y = "Wahrscheinlichkeit")
k.data <- c(1, 2, 10, 100) # Unsere Test-Kandaten
n.sim <- 10000 # Anzahl Simulationen pro k
plot.data <- data.frame() #Wir erstellen unseren Leeren Data Frame
#Wir schaffen eine Schleife indem wir jedes K einmal durchlaufen lassen
for(k in k.data){
#Wir erstellen unsere Daten für das Aktuelle K
sim.val <- rnorm.random(n.sim, k)
#Wir erschaffen einen Temporären Dataframe
temp.df <- data.frame(
#Speichern unsere Werte
werte = sim.val,
#Wir lassen die Plots damit wir sie später richtig darstellen können
k.label = factor(paste("k =", k), levels = paste("k =", k.data))
)
#Wir binden das Ergebnis an den Data Frame an
plot.data <- rbind(plot.data, temp.df)
}
#Wir erstellen unseren Plot
ggplot(plot.data, aes(x = werte)) +
#Wir erstellen wieder unser Histogram
geom_histogram(aes(y = after_stat(density)), bins = 50, fill = "skyblue",
color = "black") +
#Hierdurch erstellen wir die Plots für alle k in einem Bild
facet_wrap(~ k.label) +
#Achsenbeschriftung
labs(title = "Normalverteilungsfunktion bei verschiedenen K",
x = "Zufallszahl Z",
y = "Dichte") +
theme_minimal()
#Wir speichern die zufallszahlen in einem Data Frame für ggplot
plot.random.data <- data.frame(Zahl = random)
ggplot(plot.data.random, aes(x = factor(Zahl))) +
#Ein einfacher Barplot zählt automatisch die Häufigkeiten
geom_bar(fill = "skyblue", color = "black") +
labs(title = "Häufigkeit der gewählten Zahlen") +
theme_minimal()
#Wir speichern die zufallszahlen in einem Data Frame für ggplot
plot.random.data <- data.frame(Zahl = random)
