C24 > 20 ~ "Überdosiert",
C24 >= 15 ~ "Normaldosiert",
C24 < 15 ~ "Unterdosiert"
),
dose.class = factor(dose.class,
levels = c("Unterdosiert",
"Normaldosiert",
"Überdosiert"))
)
